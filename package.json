{
  "name": "clippy",
  "version": "1.0.0",
  "description": "Real-time clipboard sync between devices via pairing codes",
  "main": "server/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "deploy": "npm run cf:pages:deploy",
    "cf:pages:dev": "npx wrangler pages dev public",
    "cf:pages:deploy": "npx wrangler pages deploy ./public --project-name clippy-pages",
    "cf:realtime:dev": "npx wrangler dev --config cloudflare/realtime/wrangler.toml",
    "cf:realtime:deploy": "npx wrangler deploy --config cloudflare/realtime/wrangler.toml",
    "cf:deploy": "npm run cf:realtime:deploy && npm run cf:pages:deploy"
  },
  "keywords": [
    "clipboard",
    "sync",
    "realtime",
    "websocket"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
